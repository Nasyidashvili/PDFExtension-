{
    "manifest_version": 3,
    "name": "PDF Extension",
    "version": "1.0",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "webNavigation",
        "tabs"
    ],
    "web_accessible_resources": [
        {
            "resources": ["viewer.html",  "pdf.mjs", "pdf.worker.mjs"],
            "matches": ["<all_urls>"]
        }
    ]
}